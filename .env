# ================================
# Querymancer Local AI SQL Chatbot
# Environment Configuration
# ================================

# === SQL Server Database Configuration ===
# Local SQL Server Express with Windows Authentication
DB_SERVER=MECHREVO-\SQLEXPRESS
DB_DATABASE=CMS
DB_USERNAME=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_PORT=1433
DB_TRUSTED_CONNECTION=yes
DB_TRUST_CERT=true
DB_CONNECTION_TIMEOUT=80
DB_COMMAND_TIMEOUT=60

# === Ollama Model Configuration ===
# Local Ollama settings for Mistral model
MODEL_NAME=mistral
MODEL_TEMPERATURE=0.05
MODEL_MAX_TOKENS=4000
MODEL_CONTEXT_WINDOW=8192
MODEL_TIMEOUT=60
OLLAMA_BASE_URL=http://localhost:11434

# === Schema Configuration ===
# Path to your manual schema file
SCHEMA_DIR=schemas
SCHEMA_FILE=schema.json
SCHEMA_AUTO_RELOAD=true
CACHE_SCHEMA=true
VALIDATE_SCHEMA=true
FUZZY_MATCHING=true
FUZZY_THRESHOLD=0.8

# === SQL Safety & Validation ===
# Query security and validation settings
ENABLE_QUERY_VALIDATION=true
MAX_QUERY_RESULTS=1000
MAX_EXECUTION_TIME=30
VALIDATE_AGAINST_SCHEMA=true
STRICT_COLUMN_VALIDATION=true
STRICT_TABLE_VALIDATION=true
AUTO_FIX_COLUMN_NAMES=true

# === Accuracy Configuration ===
# Settings for improving SQL generation accuracy
TARGET_ACCURACY=0.99
ENABLE_FUZZY_MATCHING=true
ACCURACY_FUZZY_THRESHOLD=0.85
ENABLE_SEMANTIC_SEARCH=true
VALIDATE_JOINS=true
SUGGEST_CORRECTIONS=true
ENABLE_QUERY_OPTIMIZATION=true
CONFIDENCE_THRESHOLD=0.9
FALLBACK_TO_SCHEMA=true

# === Application Settings ===
# General application configuration
DEBUG_MODE=false
LOG_LEVEL=INFO
LOG_FILE=logs/querymancer.log
CONSOLE_LOG=true
CACHE_ENABLED=true
MAX_HISTORY=50
DB_TIMEOUT=30
AGENT_TIMEOUT=60

# === Streamlit UI Configuration ===
# Streamlit-specific settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_THEME_BASE=dark
STREAMLIT_THEME_PRIMARY_COLOR=#ff6b6b
STREAMLIT_THEME_BACKGROUND_COLOR=#0e1117
STREAMLIT_THEME_SECONDARY_BACKGROUND_COLOR=#262730
STREAMLIT_THEME_TEXT_COLOR=#fafafa

# === Performance Tuning ===
# Optional performance settings
SQL_POOL_SIZE=5
SQL_MAX_OVERFLOW=10
SQL_POOL_TIMEOUT=30
SQL_POOL_RECYCLE=3600
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# === Development Settings ===
# Only enable in development
SCHEMA_LOG=true
ACCURACY_LOG=true
MODEL_LOG=false

SQL_LOG=true
